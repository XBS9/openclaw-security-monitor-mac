<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenClawSecurityMonitorMac.Views.FirstRunWindow"
        Title="Before You Start — OpenClaw Monitor"
        Width="620" Height="780"
        MinWidth="560" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        CanResize="True"
        Background="#1A1A2E">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#B0B0C8"/>
            <Setter Property="FontFamily" Value="Inter, SF Pro Display, -apple-system, sans-serif"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#2A2A42"/>
            <Setter Property="Foreground" Value="#C0C0D8"/>
            <Setter Property="BorderBrush" Value="#3A3A55"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A58"/>
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#1E3A8A"/>
            <Setter Property="Foreground" Value="#E0E8FF"/>
            <Setter Property="BorderBrush" Value="#2D55C0"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#2D4FAA"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Border Grid.Row="0" Background="#12122A" Padding="24,18">
            <StackPanel>
                <TextBlock Text="Know Your Limits" FontSize="22" FontWeight="Bold"
                           Foreground="#EBEBF0" Margin="0,0,0,6"/>
                <TextBlock TextWrapping="Wrap" FontSize="13" Foreground="#8888A8" LineHeight="20">
                    This app provides strong protection across 9 attack vectors — but no tool
                    covers everything. Read this once so you know exactly where you stand.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Scrollable content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22,18,22,10" Spacing="10">

                <!-- What IS protected -->
                <Border Background="#0D1F0D" CornerRadius="8" BorderBrush="#1A3A1A"
                        BorderThickness="1" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="WHAT THIS APP PROTECTS" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#4ADE80"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#88C888" LineHeight="19">
                            File tampering · Credential permission drift · Brute-force auth · Egress to
                            untrusted hosts · npm patch wipeout · Plist swap · 0.0.0.0 binding ·
                            Tailscale Funnel exposure · Stale token window · Gateway process hijack ·
                            19 prompt-injection signatures in the security log.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Section header -->
                <TextBlock Text="WHAT IT CANNOT PROTECT AGAINST" FontSize="10" FontWeight="SemiBold"
                           Foreground="#F87171" Margin="0,8,0,2"/>

                <!-- Gap 1 -->
                <Border Background="#12122A" CornerRadius="8" BorderBrush="#3A1A1A"
                        BorderThickness="1" Padding="16">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="1" FontSize="11" FontWeight="Bold" Foreground="#F87171"
                                       Width="18" VerticalAlignment="Top" Margin="0,1,0,0"/>
                            <TextBlock Text="DNS Exfiltration" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#EBEBF0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8888A0" LineHeight="19"
                                   Margin="26,0,0,0">
                            The pf firewall blocks HTTP/HTTPS to untrusted hosts — but DNS queries bypass
                            it completely. A compromised AI agent can encode secrets as subdomains
                            (e.g. YOUR-API-KEY.attacker.com) and exfiltrate them invisibly via ping or
                            a DNS lookup. No firewall rule stops this.
                        </TextBlock>
                        <Border Background="#1A1A0D" CornerRadius="5" Padding="10,8" Margin="26,4,0,0">
                            <StackPanel Spacing="3">
                                <TextBlock Text="RECOMMENDATION" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FBBF24"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#C8C870" LineHeight="18">
                                    Route your Mac's DNS through NextDNS (free tier) or a local Pi-hole
                                    with a strict allowlist. This lets you log and block DNS queries to
                                    unknown domains at the resolver level — the only practical layer
                                    that can catch this.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Gap 2 -->
                <Border Background="#12122A" CornerRadius="8" BorderBrush="#3A1A1A"
                        BorderThickness="1" Padding="16">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="2" FontSize="11" FontWeight="Bold" Foreground="#F87171"
                                       Width="18" VerticalAlignment="Top" Margin="0,1,0,0"/>
                            <TextBlock Text="Indirect Prompt Injection" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#EBEBF0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8888A0" LineHeight="19"
                                   Margin="26,0,0,0">
                            Attackers hide instructions inside webpages, emails, PDFs, or API responses
                            that your AI fetches. When the AI reads the content it follows those hidden
                            instructions — fetching files, exfiltrating data, or modifying configs —
                            while appearing to do normal work. No monitor can inspect the AI's reasoning.
                        </TextBlock>
                        <Border Background="#1A1A0D" CornerRadius="5" Padding="10,8" Margin="26,4,0,0">
                            <StackPanel Spacing="3">
                                <TextBlock Text="RECOMMENDATION" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FBBF24"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#C8C870" LineHeight="18">
                                    Keep the egress allowlist active (locked mode) whenever the AI is
                                    working with external content. Review what URLs and data sources
                                    you let the AI access. Never give the AI write access to credentials
                                    or config files it doesn't need.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Gap 3 -->
                <Border Background="#12122A" CornerRadius="8" BorderBrush="#3A1A1A"
                        BorderThickness="1" Padding="16">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="3" FontSize="11" FontWeight="Bold" Foreground="#F87171"
                                       Width="18" VerticalAlignment="Top" Margin="0,1,0,0"/>
                            <TextBlock Text="MCP Tool Poisoning" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#EBEBF0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8888A0" LineHeight="19"
                                   Margin="26,0,0,0">
                            Malicious MCP servers embed hidden instructions in tool descriptions that are
                            invisible to you but read as trusted commands by the AI. A "rug pull" attack
                            changes tool behaviour silently after you have already approved the server.
                            CVE-2025-66414 and CVE-2025-66416 showed MCP SDKs had DNS rebinding
                            vulnerabilities by default.
                        </TextBlock>
                        <Border Background="#1A1A0D" CornerRadius="5" Padding="10,8" Margin="26,4,0,0">
                            <StackPanel Spacing="3">
                                <TextBlock Text="RECOMMENDATION" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FBBF24"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#C8C870" LineHeight="18">
                                    Only install MCP servers from sources you control or fully trust.
                                    Keep MCP SDK packages updated (TypeScript SDK ≥ 1.24.0,
                                    Python SDK ≥ 1.23.0). Periodically audit your openclaw.json
                                    MCP server list for unexpected additions.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Gap 4 -->
                <Border Background="#12122A" CornerRadius="8" BorderBrush="#3A1A1A"
                        BorderThickness="1" Padding="16">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="4" FontSize="11" FontWeight="Bold" Foreground="#F87171"
                                       Width="18" VerticalAlignment="Top" Margin="0,1,0,0"/>
                            <TextBlock Text="npm Supply Chain Attack" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#EBEBF0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8888A0" LineHeight="19"
                                   Margin="26,0,0,0">
                            A compromised npm package anywhere in OpenClaw's dependency tree runs with
                            full gateway privileges — access to all your tools, API keys, and workspace.
                            The s1ngularity and Shai-Hulud campaigns hit 25,000+ repositories in 2025
                            by poisoning common build packages. Auth Patches monitors specific files
                            but cannot hash the entire node_modules tree.
                        </TextBlock>
                        <Border Background="#1A1A0D" CornerRadius="5" Padding="10,8" Margin="26,4,0,0">
                            <StackPanel Spacing="3">
                                <TextBlock Text="RECOMMENDATION" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FBBF24"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#C8C870" LineHeight="18">
                                    Run `npm audit` after every OpenClaw update. Pin your OpenClaw
                                    version (`npm install -g openclaw@x.y.z`) rather than always
                                    taking `latest`. Consider using `npm ci` with a lockfile to prevent
                                    unexpected dependency changes.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Gap 5 -->
                <Border Background="#12122A" CornerRadius="8" BorderBrush="#3A1A1A"
                        BorderThickness="1" Padding="16">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="5" FontSize="11" FontWeight="Bold" Foreground="#F87171"
                                       Width="18" VerticalAlignment="Top" Margin="0,1,0,0"/>
                            <TextBlock Text="New Login Items / LaunchAgents" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#EBEBF0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8888A0" LineHeight="19"
                                   Margin="26,0,0,0">
                            Any process running as your user can write a new plist to
                            ~/Library/LaunchAgents/ and persist across every login. This monitor
                            watches your gateway's existing plist but does not detect new ones being
                            added — a common technique used by FlexibleFerret and GlassWorm malware
                            in 2025.
                        </TextBlock>
                        <Border Background="#1A1A0D" CornerRadius="5" Padding="10,8" Margin="26,4,0,0">
                            <StackPanel Spacing="3">
                                <TextBlock Text="RECOMMENDATION" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FBBF24"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#C8C870" LineHeight="18">
                                    Periodically open System Settings → General → Login Items and
                                    review everything listed. Enable macOS Lockdown Mode if you are
                                    a high-risk target. Consider Little Snitch or Lulu firewall for
                                    per-app outbound blocking — they catch new processes phoning home
                                    even before a LaunchAgent is established.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Gap 6 -->
                <Border Background="#12122A" CornerRadius="8" BorderBrush="#3A2A1A"
                        BorderThickness="1" Padding="16">
                    <StackPanel Spacing="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="6" FontSize="11" FontWeight="Bold" Foreground="#FBBF24"
                                       Width="18" VerticalAlignment="Top" Margin="0,1,0,0"/>
                            <TextBlock Text="CVE-2026-25253 — Upgrade Required" FontSize="13"
                                       FontWeight="SemiBold" Foreground="#EBEBF0"/>
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#8888A0" LineHeight="19"
                                   Margin="26,0,0,0">
                            A malicious webpage can silently steal your gateway auth token via a
                            crafted WebSocket URL — no click required beyond visiting the page.
                            This works even when your gateway is bound to localhost only. The
                            Token Age monitor limits the damage window but cannot prevent the theft.
                            CVSS 8.8. Patched in OpenClaw v2026.1.29.
                        </TextBlock>
                        <Border Background="#1A1A0D" CornerRadius="5" Padding="10,8" Margin="26,4,0,0">
                            <StackPanel Spacing="3">
                                <TextBlock Text="ACTION REQUIRED" FontSize="10" FontWeight="SemiBold"
                                           Foreground="#FBBF24"/>
                                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#C8C870" LineHeight="18">
                                    Run `openclaw --version` in Terminal. If below v2026.1.29,
                                    run `npm install -g openclaw@latest` immediately. Then rotate
                                    your gateway token with `openclaw auth rotate-token`.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Separator Background="#2A2A40" Height="1" Margin="0,8,0,0"/>
                <TextBlock TextWrapping="Wrap" FontSize="11.5" Foreground="#505068"
                           LineHeight="18" Margin="0,0,0,4">
                    This screen only shows once. You can review it anytime via About in the menu bar.
                    The 9 monitors are already running in the background.
                </TextBlock>

            </StackPanel>
        </ScrollViewer>

        <!-- Button bar -->
        <Border Grid.Row="2" Background="#12122A" BorderBrush="#2A2A40"
                BorderThickness="0,1,0,0" Padding="22,14">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Text="This app is running. The shield icon is in your menu bar."
                           FontSize="12" Foreground="#505068" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="I Understand — Let's Go"
                        Classes="primary" MinWidth="180"
                        x:Name="DismissButton"/>
            </Grid>
        </Border>

    </Grid>
</Window>
