<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenClawSecurityMonitorMac.Views.PatchWindow"
        Title="Auto-Patch — Auth Token Security"
        Width="560" Height="480"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A2E">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#B0B0C8"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#2A2A42"/>
            <Setter Property="Foreground" Value="#C0C0D8"/>
            <Setter Property="BorderBrush" Value="#3A3A55"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="14,7"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="20">

        <!-- Info section -->
        <Border Grid.Row="0" Background="#12122A" CornerRadius="8" BorderBrush="#2A2A40"
                BorderThickness="1" Padding="14" Margin="0,0,0,12">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="OpenClaw Version" FontSize="11" Foreground="#505068"/>
                        <TextBlock Text="{Binding Version}" FontSize="14" FontWeight="SemiBold" Foreground="#EBEBF0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                        <TextBlock Text="Patch Status" FontSize="11" Foreground="#505068"/>
                        <TextBlock Text="{Binding PatchStatus}" FontSize="14" FontWeight="SemiBold" Foreground="#B0C8FF"/>
                    </StackPanel>
                </Grid>
                <Button Content="Run Auto-Patch" Command="{Binding RunPatchCommand}"
                        IsEnabled="{Binding CanRunPatch}"
                        HorizontalAlignment="Left"
                        Background="#1E3A1E" BorderBrush="#2A5A2A" Foreground="#80D080"/>
            </StackPanel>
        </Border>

        <!-- Progress indicator -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" IsVisible="{Binding IsRunning}">
            <TextBlock Text="Patching in progress..." FontSize="12" Foreground="#8888A0"/>
        </StackPanel>

        <!-- Log output -->
        <Border Grid.Row="2" Background="#0E0E1E" BorderBrush="#2A2A40" BorderThickness="1" CornerRadius="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Name="LogScroll">
                <ItemsControl ItemsSource="{Binding LogLines}" Margin="10">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}"
                                       FontFamily="SF Mono, Menlo, monospace"
                                       FontSize="11" Foreground="#808098"
                                       TextWrapping="Wrap" Margin="0,1"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Note -->
        <TextBlock Grid.Row="3" Margin="0,10,0,0" FontSize="11" Foreground="#404058" TextWrapping="Wrap">
            Injects __safeTokenEqual() into OpenClaw dist files to prevent timing-based token extraction.
            On macOS, uses sed -i '' (BSD sed syntax). Run after every 'npm update -g openclaw'.
        </TextBlock>

    </Grid>
</Window>
